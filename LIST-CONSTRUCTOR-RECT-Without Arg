class rect:
    def __init__ (self):
        self.l=int(input("Enter the length:"))
        self.b=int(input("Enter the bredth:"))
    def display(self):
        return(self.l*self.b)

n=int(input("Enter the no of Rectangle:"))
l=[]
for i in range(n):
    R=rect()
    l.append(R)
for i in l:
    print("Area:",i.display())
    
