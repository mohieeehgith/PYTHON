n=int(input("Enter the num of teams:"))
teams=[]
for i in range(n):
    x=input("Enter the teams:")
    teams.append(x)
matches=[]
for i in range(n-1):
    for j in range(i+1,n):
        matches.append([teams[i],teams[j]])
pos=1       
for i in matches:
    print("Match {}.{} vs {}".format(pos,i[0],i[1]))
    pos=pos+1
